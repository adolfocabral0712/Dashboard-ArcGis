{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "dashboard-arcgis",
    "main": "src/index.js",
    "compatibility_date": "2026-07-22",

    "assets": {
        "directory": "./public",
        "binding": "ASSETS",
        "run_worker_first": [
            "/api/*"
        ]
    }
}
